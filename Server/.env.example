# Copy to .env and fill in values:
#   cp .env.example .env

# Host port for local access to the API (container listens on 5080).
HIGHSCORES_PORT=5080

# IANA timezone for score timestamps (requires tzdata in the image).
# Examples: UTC, Europe/Amsterdam, America/New_York
TZ=UTC

# Cloudflare Tunnel token from Zero Trust > Networks > Tunnels > Create tunnel.
# Required only when starting the cloudflared service:
#   docker compose --profile tunnel up -d
TUNNEL_TOKEN=

# Discord webhook for score announcements (leave empty to disable).
# Create one in Discord: Server Settings > Integrations > Webhooks.
DISCORD_WEBHOOK_URL=

# Optional "Play now" link appended to every announcement.
DISCORD_GAME_URL=

# Only announce scores that land in the top N of a level (0 = announce all).
DISCORD_ANNOUNCE_TOP_RANKS=0
