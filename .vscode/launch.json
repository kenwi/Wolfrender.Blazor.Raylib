{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Desktop (Console)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-console",
      "program": "${workspaceFolder}/bin/Debug/net10.0/Wolfrender.Blazor.Raylib.Console/Wolfrender.Blazor.Raylib.Console.dll",
      "cwd": "${workspaceFolder}/bin/Debug/net10.0/Wolfrender.Blazor.Raylib.Console",
      "console": "integratedTerminal",
      "stopAtEntry": false
    },
    {
      "name": "Desktop (Console Editor)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-console-editor",
      "program": "${workspaceFolder}/bin/Debug/net10.0/Wolfrender.Blazor.Raylib.Console.Editor/Wolfrender.Blazor.Raylib.Console.Editor.dll",
      "cwd": "${workspaceFolder}/bin/Debug/net10.0/Wolfrender.Blazor.Raylib.Console.Editor",
      "console": "integratedTerminal",
      "stopAtEntry": false
    }
  ]
}
