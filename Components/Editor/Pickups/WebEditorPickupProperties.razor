@namespace Wolfrender.Blazor.Raylib.Components.Editor
@using Game.Features.Pickups
@using Game.Editor

@if (State.SelectedPickupIndex >= 0 && State.SelectedPickupIndex < State.MapData.Pickups.Count)
{
    var pickup = State.MapData.Pickups[State.SelectedPickupIndex];

    <div class="editor-panel editor-pickup-props" @onpointerenter="OnPointerEnter" @onpointerleave="OnPointerLeave">
        <h3>Pickup Properties</h3>
        <div class="info-value">Pickup #@State.SelectedPickupIndex — @pickup.Type</div>

        <div class="info-label" style="margin-top: 6px;">Tile X</div>
        <input type="number" class="editor-input" value="@pickup.TileX" min="0" max="@(State.MapData.Width - 1)"
               @onchange="e => SetTileX(pickup, e)" />

        <div class="info-label" style="margin-top: 4px;">Tile Y</div>
        <input type="number" class="editor-input" value="@pickup.TileY" min="0" max="@(State.MapData.Height - 1)"
               @onchange="e => SetTileY(pickup, e)" />

        <div class="info-label" style="margin-top: 6px;">Amount (0 = default)</div>
        <input type="number" class="editor-input" value="@pickup.Amount" min="0"
               @onchange="e => SetAmount(pickup, e)" />

        <div class="info-label" style="margin-top: 6px;">Type</div>
        @foreach (PickupType type in Enum.GetValues<PickupType>())
        {
            var t = type;
            <button class="editor-btn @(pickup.Type == type ? "selected" : "")"
                    style="margin-right: 4px; margin-bottom: 4px;"
                    @onclick="() => SetType(pickup, t)">
                @type
            </button>
        }

        <div style="margin-top: 10px;">
            <button class="editor-btn danger" style="width: 100%;" @onclick="OnDelete">Delete Pickup</button>
        </div>
    </div>
}

@code {
    [Parameter] public EditorState State { get; set; } = default!;
    [Parameter] public EventCallback OnChanged { get; set; }

    private void SetTileX(PickupPlacement pickup, ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var val))
        {
            pickup.TileX = Math.Clamp(val, 0, State.MapData.Width - 1);
            OnChanged.InvokeAsync();
        }
    }

    private void SetTileY(PickupPlacement pickup, ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var val))
        {
            pickup.TileY = Math.Clamp(val, 0, State.MapData.Height - 1);
            OnChanged.InvokeAsync();
        }
    }

    private void SetAmount(PickupPlacement pickup, ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var val))
        {
            pickup.Amount = Math.Max(0, val);
            OnChanged.InvokeAsync();
        }
    }

    private void SetType(PickupPlacement pickup, PickupType type)
    {
        pickup.Type = type;
        State.SelectedPickupType = type;
        OnChanged.InvokeAsync();
    }

    private void OnDelete()
    {
        State.DeleteSelectedPickup();
        OnChanged.InvokeAsync();
    }

    private void OnPointerEnter() => State.IsMouseOverUI = true;
    private void OnPointerLeave() => State.IsMouseOverUI = false;
}
