@using Game.Editor

<div class="editor-panel editor-entity-props"
     style="top: @(State.EntityPropertiesPanelTop)px; right: @(State.EntityPropertiesPanelRight)px;"
     @onpointerenter="OnPointerEnter" @onpointerleave="OnPointerLeave">
    <h3 class="editor-panel-drag-handle" @onpointerdown="OnDragStart" @onpointerdown:stopPropagation="true">@Title</h3>
    @ChildContent
</div>

@code {
    [Parameter] public EditorState State { get; set; } = default!;
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private void OnDragStart(PointerEventArgs e) => State.BeginEntityPropertiesPanelDrag((float)e.ClientX, (float)e.ClientY);

    private void OnPointerEnter() => State.IsMouseOverUI = true;

    private void OnPointerLeave()
    {
        if (!State.IsDraggingEntityPropertiesPanel)
            State.IsMouseOverUI = false;
    }
}
