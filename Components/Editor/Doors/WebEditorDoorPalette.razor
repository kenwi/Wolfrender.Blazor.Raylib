@namespace Wolfrender.Blazor.Raylib.Components.Editor
@using Game.Editor
@using Game.Features.Doors

<div class="editor-panel editor-door-palette" @onpointerenter="OnPointerEnter" @onpointerleave="OnPointerLeave">
    <h3>Door Palette</h3>
    <div class="info-label">Active: @State.ActiveLayer.Name</div>

    <button class="editor-btn eraser-btn @(State.SelectedTileId == 0 ? "selected" : "")"
            @onclick="() => SelectTile(0)">
        Eraser (Empty)
    </button>

    <div class="info-label" style="margin-top: 8px;">Doors:</div>
    <div class="door-palette-grid">
        @foreach (var door in DoorTileEncoding.PaletteEntries)
        {
            var entry = door;
            <button type="button"
                    class="tile-btn @(State.SelectedTileId == entry.Id ? "selected" : "")"
                    title="@($"{entry.ShortLabel} — {entry.Description} (ID {entry.Id})")"
                    @onclick="() => SelectTile(entry.Id)">
                <span class="door-palette-preview @(entry.Vertical ? "vertical" : "")">
                    <span class="tile-palette-sprite-sheet"
                          style="@TileSpriteSheet.GetPaletteSpriteSheetStyle(entry.TextureIndex)"
                          aria-hidden="true"></span>
                    @if (entry.LockKind != DoorLockKind.None)
                    {
                        <span class="door-lock-badge @(entry.LockKind == DoorLockKind.Gold ? "gold" : "silver")">
                            @(entry.LockKind == DoorLockKind.Gold ? "G" : "S")
                        </span>
                    }
                </span>
            </button>
        }
    </div>

    <div class="info-label" style="margin-top: 6px;">
        Selected: @(State.SelectedTileId == 0 ? "Eraser" : DoorTileEncoding.GetPaletteLabel(State.SelectedTileId))
    </div>
</div>

@code {
    [Parameter] public EditorState State { get; set; } = default!;
    [Parameter] public EventCallback OnChanged { get; set; }

    private void SelectTile(uint tileId)
    {
        State.SelectedTileId = tileId;
        State.SwitchToDoorLayer();
        OnChanged.InvokeAsync();
    }

    private void OnPointerEnter() => State.IsMouseOverUI = true;
    private void OnPointerLeave() => State.IsMouseOverUI = false;
}
